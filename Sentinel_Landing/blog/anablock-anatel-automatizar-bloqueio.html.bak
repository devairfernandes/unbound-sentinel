        // Floating CTA Logic
        const floatCta = document.querySelector('.floating-cta');
        if(floatCta) {
            window.addEventListener('scroll', () => {
                const footer = document.querySelector('footer');
                const footerRect = footer ? footer.getBoundingClientRect() : null;
                const isNearFooter = footerRect ? footerRect.top < window.innerHeight : false;
                
                if(window.scrollY > 600 && !isNearFooter) floatCta.classList.add('visible');
                else floatCta.classList.remove('visible');
            });
        }
    </script>
