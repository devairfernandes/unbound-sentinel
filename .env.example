# =============================================
# UNBOUND SENTINEL — CONFIGURAÇÃO DE AMBIENTE
# =============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Porta do dashboard (padrão: 3000)
PORT=3000

# ---- ACESSO AO DASHBOARD (login no navegador) ----
DASH_USER=admin
DASH_PASS=SuaSenhaSegura123

# ---- CONEXÃO SSH COM O SERVIDOR UNBOUND ----
# Se o dashboard está no mesmo servidor do Unbound, use 127.0.0.1
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USER=root
SSH_PASS=SuaSenhaSSH
